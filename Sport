<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Menu Canali Streaming</title>
<style>
/* Reset base */
* { box-sizing: border-box; margin: 0; padding: 0; }

/* Corpo principale */
body, html {
    width: 100%;
    height: 100%;
    font-family: Arial, sans-serif;
    background-color: #111;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-top: 2rem;
}

/* Titolo pagina */
h1 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
}

/* Griglia dei canali */
.channel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.5rem;
    width: 90%;
    max-width: 1200px;
    text-align: center;
}

/* Singolo canale */
.channel-item {
    background-color: #222;
    border-radius: 12px;
    padding: 1.5rem;
    font-size: 1.2rem;
    cursor: pointer;
    transition: transform 0.3s, background-color 0.3s;
}
.channel-item:hover {
    background-color: #ff6600;
    transform: scale(1.05);
}

/* Player video */
#player-container {
    margin-top: 2rem;
    width: 90%;
    max-width: 800px;
}
video {
    width: 100%;
    border-radius: 12px;
}

/* Responsive font e padding */
@media (min-width: 768px) {
    h1 { font-size: 2.5rem; }
    .channel-item { font-size: 1.5rem; padding: 2rem; }
}
@media (min-width: 1200px) {
    h1 { font-size: 3rem; }
    .channel-item { font-size: 1.8rem; padding: 2.5rem; }
}
</style>
</head>
<body>

<h1>Menu Canali Streaming</h1>

<div class="channel-grid">
    <div class="channel-item" onclick="playChannel('http://admin.9kvgfqnluc.hitro879.xyz:80/live/carla20/20carla/22.m3u8')">Sky Sport 24</div>
    <div class="channel-item" onclick="playChannel('http://admin.9kvgfqnluc.hitro879.xyz:80/live/carla20/20carla/19.m3u8')">Sky Sport Uno</div>
    <div class="channel-item" onclick="playChannel('http://admin.9kvgfqnluc.hitro879.xyz:80/live/carla20/20carla/27956.m3u8')">Sky Sport Arena</div>
    <div class="channel-item" onclick="playChannel('http://admin.9kvgfqnluc.hitro879.xyz:80/live/carla20/20carla/150804.m3u8')">Sky Sport Max</div>
    <div class="channel-item" onclick="playChannel('http://admin.9kvgfqnluc.hitro879.xyz:80/live/carla20/20carla/25.m3u8')">Sky Sport Calcio</div>
</div>

<div id="player-container">
    <video id="player" controls></video>
</div>

<script>
// Funzione per riprodurre canale
function playChannel(url) {
    const player = document.getElementById('player');
    player.src = url; // supporta M3U8 (HLS)
    player.play();
}
</script>

</body>
</html>
